{
  "name": "recytech-shop-site",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone shop prototype for RecyTech with admin, Stripe, and Swiss Bitcoin Pay support.",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "check": "node scripts/check-syntax.js",
    "lint": "eslint .",
    "test": "node --test",
    "verify": "npm run check && npm run lint && npm test && npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-session": "^1.18.1",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "stripe": "^22.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "playwright": "^1.61.0"
  }
}
