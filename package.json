{
  "name": "recytech-shop-site",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone shop for RecyTech with admin, Stripe, and Swiss Bitcoin Pay support.",
  "main": "server.js",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "check": "node scripts/check-syntax.js",
    "lint": "eslint . --max-warnings=0",
    "test": "node --test",
    "coverage": "node --test --experimental-test-coverage",
    "coverage:check": "node scripts/check-coverage.js",
    "backup:sqlite": "node scripts/backup-sqlite.js",
    "backup:verify": "node scripts/verify-sqlite-backup.js",
    "health:check": "node scripts/check-health.js",
    "verify": "npm run check && npm run lint && npm test && npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-session": "^1.18.1",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "sharp": "^0.35.2",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "playwright": "^1.61.1"
  }
}
