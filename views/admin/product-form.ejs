<%- include("../partials/head", { title }) %>
<%- include("../partials/header") %>
<%- include("../partials/flash") %>

<main class="shell section-stack admin-page">
    <section class="section-block">
        <div class="section-heading admin-section-heading">
            <div>
                <p class="eyebrow">Administration</p>
                <h1><%= product ? "Modifier le produit" : "Nouveau produit" %></h1>
            </div>
            <a href="/admin" class="button button-secondary">Retour</a>
        </div>

        <form action="<%= formAction %>" method="post" class="admin-form-grid" enctype="multipart/form-data">
            <%- include("../partials/csrf-field") %>
            <label>
                Nom du produit
                <input type="text" name="name" value="<%= product?.name || '' %>" required>
            </label>

            <label class="full-span">
                Catégories
                <textarea name="categories" rows="3" placeholder="Ordinateur&#10;Portable&#10;Lenovo"><%= product?.categories_text || product?.category || '' %></textarea>
                <small>Une catégorie par ligne, ou séparées par des virgules. Les nouvelles catégories seront créées à l'enregistrement.</small>
                <% if (categories.length) { %>
                    <small>Déjà utilisées : <%= categories.join(", ") %></small>
                <% } %>
            </label>

            <label>
                Prix en CHF
                <input type="number" name="price_chf" min="0" step="0.01" value="<%= product ? (product.price_cents / 100).toFixed(2) : '' %>" required>
            </label>

            <label>
                Stock
                <input type="number" name="inventory" min="0" step="1" value="<%= product?.inventory || 0 %>" required>
            </label>

            <label>
                Image URL ou chemin
                <input type="text" name="image_url" value="<%= product?.image_url || '' %>" placeholder="https://... ou /static/images/...">
                <small>Accepte une URL complète ou un chemin du site, par exemple `/static/uploads/products/image.jpg`.</small>
            </label>

            <label>
                Importer l'image principale
                <input type="file" name="image_file" accept="image/*">
                <small>Remplace l'URL ci-dessus si une image est sélectionnée.</small>
            </label>

            <label class="full-span">
                Galerie photos
                <textarea name="image_gallery_urls" rows="5" placeholder="https://.../photo-2.jpg&#10;https://.../photo-3.jpg"><%= product?.image_gallery_text || '' %></textarea>
                <small>Une URL par ligne. L'image principale ci-dessus reste la photo d'ouverture.</small>
            </label>

            <label class="full-span">
                Importer des photos de galerie
                <input type="file" name="gallery_files" accept="image/*" multiple>
                <small>Les images importées seront ajoutées à la galerie existante.</small>
            </label>

            <label class="full-span">
                Résumé court
                <input type="text" name="short_description" value="<%= product?.short_description || '' %>" required>
            </label>

            <label class="full-span">
                Description détaillée
                <textarea name="description" rows="8"><%= product?.description || '' %></textarea>
            </label>

            <label class="full-span">
                Notes privées admin
                <textarea name="admin_notes" rows="5" placeholder="État interne, accessoires manquants, diagnostic, suivi de préparation..."><%= product?.admin_notes || '' %></textarea>
                <small>Visible uniquement dans l'administration. Ces notes ne sont pas affichées sur la boutique.</small>
            </label>

            <label class="full-span">
                Options du produit
                <textarea name="option_groups" rows="5" placeholder="État esthétique: Parfait | Bon | Acceptable&#10;Batterie: Excellente | Bonne | Moyenne"><%= product?.option_groups_text || '' %></textarea>
                <small>Une ligne par groupe, au format `Nom: valeur 1 | valeur 2 | valeur 3`.</small>
            </label>

            <label class="full-span">
                Combinaisons autorisées et prix
                <textarea name="valid_configurations" rows="6" placeholder="État esthétique=Parfait ; Batterie=Bonne => 220.00&#10;État esthétique=Bon ; Batterie=Excellente => 240.00&#10;État esthétique=Bon ; Batterie=Bonne"><%= product?.valid_configurations_text || '' %></textarea>
                <small>Laissez vide pour autoriser toutes les combinaisons possibles. Sinon, une ligne = une configuration disponible, au format `Option=valeur ; Option=valeur`. Ajoutez `=> 249.00` pour définir le prix final de cette configuration; sans prix, le prix du produit est utilisé.</small>
            </label>

            <label class="full-span">
                Informations complémentaires
                <textarea name="info_rows" rows="8" placeholder="Processeur: Intel Core i5-8365U&#10;Mémoire: 16 Go&#10;Stockage: SSD 512 Go"><%= product?.info_rows_text || '' %></textarea>
                <small>Une ligne par information, au format `Libellé: valeur`.</small>
            </label>

            <label class="choice-card choice-card-checkbox">
                <input type="checkbox" name="featured" value="1" <%= product?.featured ? "checked" : "" %>>
                <span class="choice-surface">
                    <span class="choice-indicator" aria-hidden="true"></span>
                    <span class="choice-card-copy">
                        <strong>Mettre en avant</strong>
                        <small>Afficher ce produit dans la sélection mise en avant.</small>
                    </span>
                </span>
            </label>

            <label class="choice-card choice-card-checkbox">
                <input type="checkbox" name="published" value="1" <%= product?.published ? "checked" : "" %>>
                <span class="choice-surface">
                    <span class="choice-indicator" aria-hidden="true"></span>
                    <span class="choice-card-copy">
                        <strong>Publier sur la boutique</strong>
                        <small>Rendre le produit visible pour les visiteurs.</small>
                    </span>
                </span>
            </label>

            <div class="full-span form-actions">
                <button type="submit" class="button">Enregistrer</button>
                <% if (product) { %>
                    <button
                        type="submit"
                        form="delete-product-form"
                        class="button button-ghost"
                    >
                        Supprimer le produit
                    </button>
                <% } %>
            </div>
        </form>
        <% if (product) { %>
            <form
                id="delete-product-form"
                action="/admin/products/<%= product.id %>/delete"
                method="post"
                class="inline-danger-form"
                data-confirm-form
                data-confirm-title="Supprimer le produit"
                data-confirm-message="Ce produit sera supprimé définitivement. Cette action est irréversible."
                data-confirm-submit="Supprimer"
            >
                <%- include("../partials/csrf-field") %>
            </form>
        <% } %>
    </section>
</main>

<%- include("../partials/footer") %>
