<%- include("../partials/head", { title }) %>
<%- include("../partials/header") %>
<%- include("../partials/flash") %>

<main class="shell section-stack admin-page">
    <section class="section-heading admin-section-heading">
        <div>
            <p class="eyebrow">Administration</p>
            <h1>Codes promo</h1>
        </div>
        <div class="admin-actions">
            <a href="/admin/promo-codes/new" class="button">Créer un code promo</a>
            <a href="/admin" class="button button-secondary">Retour au tableau de bord</a>
        </div>
    </section>

    <section class="section-block">
        <% if (!promoCodes.length) { %>
            <div class="empty-state compact">
                <p>Aucun code promo pour l'instant.</p>
            </div>
        <% } else { %>
            <div class="table-wrap table-wrap-admin">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Réduction</th>
                            <th>Conditions</th>
                            <th>Utilisations</th>
                            <th>Statut</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% promoCodes.forEach((promoCode) => { %>
                            <tr>
                                <td data-label="Code">
                                    <strong><%= promoCode.code %></strong>
                                    <% if (promoCode.description) { %>
                                        <div class="muted"><%= promoCode.description %></div>
                                    <% } %>
                                </td>
                                <td data-label="Réduction"><%= formatPromoCodeDiscount(promoCode) %></td>
                                <td data-label="Conditions">
                                    <div>Minimum: <%= promoCode.minimum_order_cents > 0 ? formatMoney(promoCode.minimum_order_cents) : "Aucun" %></div>
                                    <div class="muted">
                                        <%= promoCode.starts_on || "Immédiat" %> → <%= promoCode.expires_on || "Sans fin" %>
                                    </div>
                                </td>
                                <td data-label="Utilisations">
                                    <div><%= promoCode.times_redeemed %> utilisée(s)</div>
                                    <div class="muted">
                                        <%= Number.isInteger(promoCode.max_redemptions) ? `Limite : ${promoCode.max_redemptions}` : "Sans limite" %>
                                    </div>
                                </td>
                                <td data-label="Statut"><span class="chip chip-<%= getPromoCodeStatusTone(promoCode) %>"><%= getPromoCodeStatus(promoCode) %></span></td>
                                <td class="order-actions-cell" data-label="Actions">
                                    <div class="row-actions">
                                        <a href="/admin/promo-codes/<%= promoCode.id %>/edit">Modifier</a>
                                        <form
                                            action="/admin/promo-codes/<%= promoCode.id %>/delete"
                                            method="post"
                                            data-confirm-form
                                            data-confirm-title="Supprimer le code promo"
                                            data-confirm-message="Ce code promo sera supprimé définitivement. Cette action est irréversible."
                                            data-confirm-submit="Supprimer"
                                        >
                                            <%- include("../partials/csrf-field") %>
                                            <button type="submit">Supprimer</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </section>
</main>

<%- include("../partials/footer") %>
