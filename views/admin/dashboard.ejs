<%- include("../partials/head", { title }) %>
<%- include("../partials/header") %>
<%- include("../partials/flash") %>

<main class="shell section-stack admin-page">
    <section class="section-heading admin-section-heading">
        <div>
            <p class="eyebrow">Administration</p>
            <h1>Tableau de bord</h1>
        </div>
        <div class="admin-actions">
            <a href="/admin/account" class="button button-secondary">Mon compte</a>
            <a href="/admin/promo-codes" class="button button-secondary">Codes promo</a>
            <% if (currentAdmin?.role === "superadmin") { %>
                <a href="/admin/admins" class="button button-secondary">Gérer les admins</a>
            <% } %>
            <a href="/admin/settings" class="button button-secondary">Paramètres</a>
            <form action="/admin/logout" method="post">
                <%- include("../partials/csrf-field") %>
                <button class="button button-ghost" type="submit">Se déconnecter</button>
            </form>
        </div>
    </section>

    <section class="admin-stat-grid">
        <article class="admin-stat-card">
            <span>Produits</span>
            <strong><%= stats.products %></strong>
        </article>
        <article class="admin-stat-card">
            <span>Publiés</span>
            <strong><%= stats.publishedProducts %></strong>
        </article>
        <article class="admin-stat-card">
            <span>Commandes payées</span>
            <strong><%= stats.paidOrders %></strong>
        </article>
        <article class="admin-stat-card">
            <span>Chiffre d'affaires</span>
            <strong><%= formatMoney(stats.revenueCents) %></strong>
        </article>
        <article class="admin-stat-card">
            <span>Codes promo actifs</span>
            <strong><%= stats.activePromoCodes %></strong>
        </article>
    </section>

    <section class="section-block">
        <div class="section-heading admin-section-heading">
            <div>
                <p class="eyebrow">Catalogue</p>
                <h2>Produits</h2>
            </div>
            <a href="/admin/products/new" class="button">Ajouter un produit</a>
        </div>

        <% if (!products.length) { %>
            <div class="empty-state compact">
                <p>Aucun produit pour l'instant.</p>
            </div>
        <% } else { %>
            <div class="table-wrap table-wrap-admin">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Nom</th>
                            <th>Catégorie</th>
                            <th>Prix</th>
                            <th>Stock</th>
                            <th>État</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% products.forEach((product) => { %>
                            <tr>
                                <td data-label="Nom">
                                    <strong><%= product.name %></strong>
                                    <% if (product.admin_notes) { %>
                                        <div class="muted">Note privée : <%= product.admin_notes.length > 90 ? `${product.admin_notes.slice(0, 90)}...` : product.admin_notes %></div>
                                    <% } %>
                                </td>
                                <td data-label="Catégorie"><%= product.category || "Non définie" %></td>
                                <td data-label="Prix"><%= formatMoney(product.price_cents, product.currency) %></td>
                                <td data-label="Stock"><%= product.inventory %></td>
                                <td data-label="État"><%= product.published ? "Publié" : "Brouillon" %></td>
                                <td class="order-actions-cell" data-label="Actions">
                                    <div class="row-actions">
                                        <a href="/admin/products/<%= product.id %>/edit">Modifier</a>
                                        <form
                                            action="/admin/products/<%= product.id %>/delete"
                                            method="post"
                                            data-confirm-form
                                            data-confirm-title="Supprimer le produit"
                                            data-confirm-message="Ce produit sera supprimé définitivement. Cette action est irréversible."
                                            data-confirm-submit="Supprimer"
                                        >
                                            <%- include("../partials/csrf-field") %>
                                            <button type="submit">Supprimer</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </section>

    <section class="section-block">
        <div class="section-heading admin-section-heading">
            <div>
                <p class="eyebrow">Commandes</p>
                <h2>Dernières commandes</h2>
            </div>
            <div class="admin-actions">
                <a href="/admin/orders/new" class="button">Créer une commande</a>
                <a href="/admin/orders" class="button button-secondary">Voir toutes les commandes</a>
            </div>
        </div>

        <% if (!recentOrders.length) { %>
            <div class="empty-state compact">
                <p>Aucune commande enregistrée pour l'instant.</p>
            </div>
        <% } else { %>
            <div class="table-wrap table-wrap-admin">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Numéro</th>
                            <th>Date</th>
                            <th>Paiement</th>
                            <th>Client</th>
                            <th>Montant</th>
                            <th>Statut</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recentOrders.forEach((order) => { %>
                            <tr>
                                <td data-label="Numéro"><%= order.order_number %></td>
                                <td data-label="Date"><%= formatDateTime(order.created_at) %></td>
                                <td data-label="Paiement"><%= getOrderProviderLabel(order.provider) %></td>
                                <td data-label="Client"><%= order.customer_name %></td>
                                <td data-label="Montant"><%= formatMoney(order.amount_cents, order.currency) %></td>
                                <td data-label="Statut"><%= getOrderStatusLabel(order.status) %></td>
                                <td class="order-actions-cell" data-label="Actions">
                                    <div class="row-actions">
                                        <a href="/admin/orders/<%= order.id %>">Ouvrir</a>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </section>
</main>

<%- include("../partials/footer") %>
