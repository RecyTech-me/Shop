<%- include("../partials/head", { title }) %>
<%- include("../partials/header") %>
<%- include("../partials/flash") %>

<main class="shell section-stack admin-page">
    <section class="section-block">
        <div class="section-heading admin-section-heading">
            <div>
                <p class="eyebrow">Administration</p>
                <h1>Nouvelle commande manuelle</h1>
            </div>
            <a href="/admin/orders" class="button button-secondary">Retour aux commandes</a>
        </div>

        <% if (!products.length) { %>
            <div class="empty-state compact">
                <p>Aucun produit n'est disponible pour créer une commande.</p>
                <div class="form-actions">
                    <a href="/admin/products/new" class="button add-product-button">Ajouter un produit</a>
                </div>
            </div>
        <% } else { %>
            <% const manualOrderDefaultProduct = products.find((product) => product.inventory > 0) || products[0]; %>
            <form action="/admin/orders/new" method="post" class="admin-form-grid" data-manual-order-form>
                <%- include("../partials/csrf-field") %>
                <label>
                    Nom du client
                    <input type="text" name="customer_name" placeholder="Nom ou personne de contact" required>
                </label>

                <label>
                    E-mail du client
                    <input type="email" name="customer_email" placeholder="facultatif">
                </label>

                <label>
                    Téléphone
                    <input type="tel" name="customer_phone" placeholder="facultatif">
                </label>

                <label>
                    Paiement
                    <input type="text" name="payment_label" value="Vente hors site" placeholder="Espèces, Twint, virement...">
                </label>

                <label>
                    Date de commande
                    <input type="datetime-local" name="order_created_at" value="<%= formatDateTimeInputValue() %>" required>
                </label>

                <label class="full-span">
                    Produit
                    <select name="product_id" required data-manual-order-product-select>
                        <% products.forEach((product) => { %>
                            <% const productCategories = (product.categories?.length ? product.categories : (product.category ? [product.category] : [])).join(", "); %>
                            <option
                                value="<%= product.id %>"
                                data-base-price-cents="<%= product.price_cents %>"
                                data-starting-price-cents="<%= product.starting_price_cents %>"
                                data-currency="<%= product.currency %>"
                                <%= product.inventory <= 0 ? "disabled" : "" %>
                                <%= product.id === manualOrderDefaultProduct?.id ? "selected" : "" %>
                            >
                                <%= productCategories ? `${productCategories} - ` : "" %><%= product.name %> - <%= formatMoney(product.price_cents, product.currency) %> - stock <%= product.inventory %>
                            </option>
                        <% }) %>
                    </select>
                </label>

                <% const productsWithOptions = products.filter((product) => (product.option_groups || []).length); %>
                <% if (productsWithOptions.length) { %>
                    <div class="full-span manual-order-options" data-manual-order-options>
                        <% productsWithOptions.forEach((product) => { %>
                            <% const panelActive = product.id === manualOrderDefaultProduct?.id; %>
                            <div
                                class="manual-order-option-panel"
                                data-manual-order-option-panel
                                data-product-id="<%= product.id %>"
                                data-base-price-cents="<%= product.price_cents %>"
                                data-starting-price-cents="<%= product.starting_price_cents %>"
                                data-currency="<%= product.currency %>"
                                data-valid-configurations="<%= JSON.stringify(product.valid_configurations || []) %>"
                                <%= panelActive ? "" : "hidden" %>
                            >
                                <div>
                                    <p class="eyebrow">Options du produit</p>
                                    <strong><%= product.name %></strong>
                                </div>
                                <div class="manual-order-option-grid">
                                    <% product.option_groups.forEach((group, index) => { %>
                                        <label>
                                            <%= group.name %>
                                            <select
                                                name="selected_option_<%= index %>"
                                                data-manual-order-option-select
                                                data-option-index="<%= index %>"
                                                data-option-group="<%= group.name %>"
                                                <%= panelActive ? "required" : "" %>
                                                <%= panelActive ? "" : "disabled" %>
                                            >
                                                <option value="">Choisir une option</option>
                                                <% group.values.forEach((value) => { %>
                                                    <option value="<%= value %>"><%= value %></option>
                                                <% }) %>
                                            </select>
                                        </label>
                                    <% }) %>
                                </div>
                                <p class="product-option-message" data-manual-order-option-message hidden></p>
                                <small data-manual-order-price-hint></small>
                            </div>
                        <% }) %>
                    </div>
                <% } %>

                <label>
                    Quantité
                    <input type="number" name="quantity" min="1" step="1" value="1" required>
                </label>

                <label>
                    Prix unitaire personnalisé (CHF)
                    <input type="number" name="unit_price_chf" min="0" step="0.01" placeholder="Laisser vide = prix produit" data-manual-order-unit-price>
                </label>

                <label>
                    Remise (CHF)
                    <input type="number" name="discount_chf" min="0" step="0.01" placeholder="0.00">
                    <small>Montant déduit du total de cette commande.</small>
                </label>

                <label>
                    Code promo utilisé
                    <input type="text" name="promo_code" list="manual-order-promo-codes" placeholder="facultatif" autocapitalize="characters" autocomplete="off">
                    <small>Si aucune remise manuelle n'est saisie, le code valide calcule la remise automatiquement.</small>
                </label>

                <label>
                    Statut
                    <select name="status">
                        <% orderStatusOptions.forEach((option) => { %>
                            <option value="<%= option.value %>" <%= option.value === "paid" ? "selected" : "" %>><%= option.label %></option>
                        <% }) %>
                    </select>
                    <small>Un statut payé ou traité décrémente le stock automatiquement.</small>
                </label>

                <label class="full-span">
                    Note interne
                    <textarea name="internal_note" rows="4" placeholder="Contexte de la vente, retrait, paiement, accord spécial..."></textarea>
                </label>

                <div class="full-span form-actions">
                    <button type="submit" class="button">Créer la commande</button>
                </div>

                <datalist id="manual-order-promo-codes">
                    <% promoCodes.forEach((promoCode) => { %>
                        <option value="<%= promoCode.code %>"><%= formatPromoCodeDiscount(promoCode) %></option>
                    <% }) %>
                </datalist>
            </form>
        <% } %>
    </section>
</main>

<%- include("../partials/footer") %>
