<%- include("partials/head", { title }) %>
<%- include("partials/header") %>
<%- include("partials/flash") %>

<section class="hero">
    <div class="shell hero-grid">
        <% const heroImageUrl = settings.hero_image_url || "/static/images/illustrations/hero-workshop.jpg"; %>
        <div class="hero-copy" style="--hero-image: url(<%= JSON.stringify(heroImageUrl) %>);">
            <h1><%= settings.hero_title %></h1>
            <p class="hero-text"><%= settings.hero_text %></p>
            <div class="hero-actions">
                <a href="#catalogue" class="button">Voir les produits</a>
                <a href="/cart" class="button button-secondary">Voir le panier</a>
            </div>
            <% const heroPoints = String(settings.hero_points || "")
                .split(/\r?\n/)
                .map((point) => point.trim())
                .filter(Boolean); %>
            <% if (heroPoints.length) { %>
                <ul class="hero-points">
                    <% heroPoints.forEach((point) => { %>
                        <li><%= point %></li>
                    <% }) %>
                </ul>
            <% } %>
        </div>
    </div>
</section>

<main class="shell section-stack">
    <section class="section-block" id="catalogue">
        <div class="section-heading catalogue-heading">
            <div>
                <p class="eyebrow">Catalogue</p>
                <h2>Matériel disponible</h2>
            </div>
            <form action="/#catalogue" method="get" class="catalogue-filters" aria-label="Filtrer le catalogue">
                <label class="catalogue-filter-compact">
                    <span>Catégorie</span>
                    <select name="category" data-catalogue-auto-submit>
                        <option value="">Toutes</option>
                        <% catalogueCategories.forEach((category) => { %>
                            <option value="<%= category %>" <%= catalogueFilters.category === category ? "selected" : "" %>><%= category %></option>
                        <% }) %>
                    </select>
                </label>
                <label class="catalogue-filter-compact">
                    <span>Tri</span>
                    <select name="sort" data-catalogue-auto-submit>
                        <option value="random" <%= catalogueFilters.sort === "random" ? "selected" : "" %>>Aléatoire</option>
                        <option value="featured" <%= catalogueFilters.sort === "featured" ? "selected" : "" %>>Mis en avant</option>
                        <option value="newest" <%= catalogueFilters.sort === "newest" ? "selected" : "" %>>Plus récents</option>
                        <option value="price_asc" <%= catalogueFilters.sort === "price_asc" ? "selected" : "" %>>Prix croissant</option>
                        <option value="price_desc" <%= catalogueFilters.sort === "price_desc" ? "selected" : "" %>>Prix décroissant</option>
                        <option value="name_asc" <%= catalogueFilters.sort === "name_asc" ? "selected" : "" %>>Nom A-Z</option>
                    </select>
                </label>
                <details class="catalogue-filter-more <%= (catalogueFilters.q || catalogueFilters.price_min || catalogueFilters.price_max || catalogueFilters.availability) ? "catalogue-filter-more-active" : "" %>">
                    <summary class="catalogue-search-toggle" aria-label="Recherche et filtres avancés">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="11" cy="11" r="6"></circle>
                            <path d="m16 16 4 4"></path>
                        </svg>
                        <span class="visually-hidden">Recherche et filtres avancés</span>
                    </summary>
                    <div class="catalogue-filter-panel">
                        <label>
                            Recherche
                            <input type="search" name="q" value="<%= catalogueFilters.q %>" placeholder="Nom, description...">
                        </label>
                        <label>
                            Prix min.
                            <input type="number" name="price_min" min="0" step="0.01" value="<%= catalogueFilters.price_min %>" placeholder="0">
                        </label>
                        <label>
                            Prix max.
                            <input type="number" name="price_max" min="0" step="0.01" value="<%= catalogueFilters.price_max %>" placeholder="200">
                        </label>
                        <label>
                            Disponibilité
                            <select name="availability">
                                <option value="" <%= !catalogueFilters.availability ? "selected" : "" %>>Tous</option>
                                <option value="in_stock" <%= catalogueFilters.availability === "in_stock" ? "selected" : "" %>>En stock</option>
                                <option value="out_of_stock" <%= catalogueFilters.availability === "out_of_stock" ? "selected" : "" %>>Rupture</option>
                            </select>
                        </label>
                        <div class="catalogue-filter-actions">
                            <button type="submit" class="button button-small">Appliquer</button>
                            <% if (hasCatalogueFilters) { %>
                                <a href="/#catalogue" class="button button-secondary button-small">Réinitialiser</a>
                            <% } %>
                        </div>
                    </div>
                </details>
            </form>
        </div>

        <% if (!products.length) { %>
            <div class="empty-state">
                <% if (hasCatalogueFilters) { %>
                    <h3>Aucun produit ne correspond à ces filtres.</h3>
                    <p>Essaie d'élargir la catégorie, le prix ou la disponibilité.</p>
                <% } else { %>
                    <h3>Le catalogue sera bientôt disponible.</h3>
                    <p>Les premiers ordinateurs et accessoires sont en cours d'ajout.</p>
                <% } %>
            </div>
        <% } else { %>
            <div class="product-grid catalogue-grid">
                <% products.forEach((product) => { %>
                    <article class="product-card catalogue-card">
                        <a href="/products/<%= product.slug %>" class="product-thumb catalogue-thumb" aria-label="<%= product.name %>">
                            <% if (product.image_url) { %>
                                <img src="<%= product.image_url %>" alt="" loading="lazy" referrerpolicy="no-referrer" onerror="this.hidden=true;this.nextElementSibling.hidden=false;this.parentElement.classList.add('catalogue-thumb-empty');">
                                <span class="catalogue-thumb-fallback" hidden><%= product.name %></span>
                            <% } else { %>
                                <span class="catalogue-thumb-fallback"><%= product.name %></span>
                            <% } %>
                        </a>
                        <div class="product-body catalogue-body">
                            <div class="product-meta">
                                <% const productCategories = product.categories?.length ? product.categories : (product.category ? [product.category] : []); %>
                                <% productCategories.forEach((category) => { %>
                                    <span class="chip chip-muted"><%= category %></span>
                                <% }) %>
                                <% if (product.is_pack) { %>
                                    <span class="chip chip-info">Pack</span>
                                <% } %>
                                <% if (product.featured) { %>
                                    <span class="chip">À la une</span>
                                <% } %>
                                <span class="chip chip-muted"><%= product.inventory %> en stock</span>
                            </div>
                            <h3><a href="/products/<%= product.slug %>"><%= product.name %></a></h3>
                            <div class="product-footer catalogue-footer">
                                <strong class="catalogue-price"><%= formatProductPrice(product) %></strong>
                                <% if (product.inventory > 0) { %>
                                    <div class="catalogue-action">
                                        <a href="/products/<%= product.slug %>" class="button button-block">Voir plus</a>
                                    </div>
                                <% } else { %>
                                    <span class="chip chip-muted">Rupture</span>
                                <% } %>
                            </div>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } %>
    </section>

    <section class="section-block review-section" id="reviews">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Avis clients</p>
                <h2>Ce qu'ils pensent de RecyTech</h2>
            </div>
            <% if (reviewSummary?.count) { %>
                <% const averageRatingLabel = Number.isInteger(reviewSummary.averageRating) ? String(reviewSummary.averageRating) : reviewSummary.averageRating.toFixed(1); %>
                <div class="review-summary">
                    <strong><%= averageRatingLabel %>/5</strong>
                    <span><%= reviewSummary.count %> avis publié<%= reviewSummary.count > 1 ? "s" : "" %></span>
                </div>
            <% } %>
        </div>

        <% if (reviews?.length) { %>
            <div class="review-list">
                <% reviews.forEach((review) => { %>
                    <article class="review-card">
                        <div class="review-card-header">
                            <div>
                                <strong><%= review.reviewer_name %></strong>
                                <p class="muted"><%= formatDateTime(review.created_at) %></p>
                            </div>
                            <div class="review-stars" aria-label="<%= review.rating %> sur 5">
                                <% for (let star = 1; star <= 5; star += 1) { %>
                                    <span class="<%= star <= review.rating ? 'is-filled' : '' %>">★</span>
                                <% } %>
                            </div>
                        </div>
                        <% if (review.title) { %>
                            <h3><%= review.title %></h3>
                        <% } %>
                        <p><%= review.body %></p>
                    </article>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state compact">
                <p>Aucun avis publié pour l'instant.</p>
            </div>
        <% } %>

        <form action="/reviews" method="post" class="review-form">
            <%- include("partials/csrf-field") %>
            <div>
                <p class="eyebrow">Votre avis</p>
                <h3>Partager votre expérience</h3>
            </div>
            <div class="review-form-grid">
                <label>
                    Note
                    <select name="rating" required>
                        <option value="">Choisir</option>
                        <option value="5">5 - Excellent</option>
                        <option value="4">4 - Très bien</option>
                        <option value="3">3 - Bien</option>
                        <option value="2">2 - Moyen</option>
                        <option value="1">1 - Décevant</option>
                    </select>
                </label>
                <label>
                    Nom
                    <input type="text" name="reviewer_name" maxlength="80" required>
                </label>
                <label>
                    E-mail
                    <input type="email" name="reviewer_email" maxlength="160" placeholder="Non publié">
                </label>
                <label class="full-span">
                    Titre
                    <input type="text" name="title" maxlength="120" placeholder="Résumé en quelques mots">
                </label>
                <label class="full-span">
                    Avis
                    <textarea name="body" rows="5" minlength="10" maxlength="1200" required></textarea>
                    <small>Merci ! Nous vérifions les avis avant publication pour éviter le spam.</small>
                </label>
            </div>
            <div class="form-actions">
                <button type="submit" class="button">Envoyer l'avis</button>
            </div>
        </form>
    </section>
</main>

<%- include("partials/footer") %>
