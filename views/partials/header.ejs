<header class="site-header" data-site-header>
    <% if (currentAdmin) { %>
        <div class="admin-bar" data-admin-bar>
            <div class="shell admin-bar-shell">
                <div class="admin-bar-topline">
                    <div class="admin-bar-copy">
                        <strong>Connecté en admin</strong>
                        <span><%= currentAdmin.username %> · <%= getAdminRoleLabel(currentAdmin.role) %></span>
                    </div>
                    <button
                        class="admin-bar-toggle"
                        type="button"
                        aria-expanded="false"
                        aria-controls="admin-bar-nav"
                        aria-label="Ouvrir le menu admin"
                        data-admin-menu-toggle
                    >
                        <span class="admin-bar-toggle-bar"></span>
                        <span class="admin-bar-toggle-bar"></span>
                        <span class="admin-bar-toggle-bar"></span>
                    </button>
                </div>
                <div class="admin-bar-actions" id="admin-bar-nav" data-admin-nav>
                    <a href="/">Voir la boutique</a>
                    <a href="/admin">Tableau de bord</a>
                    <a href="/admin/account">Mon compte</a>
                    <a href="/admin/orders">Commandes</a>
                    <a href="/admin/promo-codes">Codes promo</a>
                    <% if (currentAdmin.role === "superadmin") { %>
                        <a href="/admin/admins">Admins</a>
                    <% } %>
                    <a href="/admin/products/new">Ajouter un produit</a>
                    <a href="/admin/settings">Paramètres</a>
                    <form action="/admin/logout" method="post">
                        <%- include("csrf-field") %>
                        <button type="submit">Se déconnecter</button>
                    </form>
                </div>
            </div>
        </div>
    <% } %>
    <div class="shell header-shell">
        <a href="/" class="brand">
            <img src="/static/images/recytech-logo.svg" alt="RecyTech">
            <span><%= settings.store_name %></span>
        </a>
        <button
            class="site-menu-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="site-nav"
            aria-label="Ouvrir le menu"
            data-site-menu-toggle
        >
            <span class="site-menu-toggle-bar"></span>
            <span class="site-menu-toggle-bar"></span>
            <span class="site-menu-toggle-bar"></span>
        </button>
        <nav class="site-nav" id="site-nav" data-site-nav>
            <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Boutique</a>
            <a href="/cart" class="<%= currentPath === '/cart' ? 'active' : '' %>">
                <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M3 4h2l2.1 9.2A2 2 0 0 0 9.05 15H18a2 2 0 0 0 1.94-1.5L21 8H7"></path>
                    <circle cx="10" cy="19" r="1.75"></circle>
                    <circle cx="17" cy="19" r="1.75"></circle>
                </svg>
                <span>Panier (<%= cart.itemCount %>)</span>
            </a>
            <% if (currentAdmin) { %>
                <a href="/admin" class="<%= currentPath.startsWith('/admin') ? 'active' : '' %>">Admin</a>
            <% } else { %>
                <a href="/admin/login" class="<%= currentPath === '/admin/login' ? 'active' : '' %>">
                    <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Z"></path>
                        <path d="M4 20a8 8 0 0 1 16 0"></path>
                    </svg>
                    <span>Connexion</span>
                </a>
            <% } %>
        </nav>
    </div>
</header>
